{
  "profiles": {
    "RequestHub.Server": { //local Dev env
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "dotnetRunMessages": true,
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}",
      "applicationUrl": "https://localhost:7252;http://localhost:5200"
    },
    "AzureProduction": { //local Prod env
      "commandName": "Project",
      "launchBrowser": true,
      "environmentalVariabels": {
        "ASPNETCORE_ENVIRONMENT": "Production"
      }
    }
  }
}